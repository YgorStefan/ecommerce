# .env.example
# Copie este arquivo para .env e preencha com seus valores reais

# ========================
# BANCO DE DADOS (MySQL - Hostinger)
# ========================
DB_HOST=localhost
DB_PORT=3306
DB_USER=seu_usuario_mysql
DB_PASSWORD=sua_senha_mysql
DB_NAME=seu_banco_mysql

# ========================
# BACKEND
# ========================
BACKEND_PORT=3001
NODE_ENV=production

# Segredos JWT — use strings longas e aleatórias em produção
JWT_ACCESS_SECRET=gere_uma_string_longa_aleatoria_aqui
JWT_REFRESH_SECRET=gere_outra_string_longa_aleatoria_aqui
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ========================
# FRONTEND
# ========================
FRONTEND_PORT=3000

# URL do frontend — usada pelo backend para liberar CORS
FRONTEND_URL=https://ygorstefan.com

# URL do backend vista pelo BROWSER (passa pelo proxy do Next.js)
# Não mude isso — o browser chama /ecommerce/api/* e o Next.js repassa para o NestJS
NEXT_PUBLIC_API_URL=https://ygorstefan.com/ecommerce

# URL interna do NestJS — usada pelo Next.js server-side para chamar o backend diretamente
# Nunca exposta ao browser
INTERNAL_API_URL=http://localhost:3001

# URL pública do site — usada para SEO e sitemap
NEXT_PUBLIC_SITE_URL=https://ygorstefan.com/ecommerce

# ========================
# E-MAIL (SMTP)
# ========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seu_email@gmail.com
MAIL_PASSWORD=sua_app_password_gmail
MAIL_FROM=E-commerce <noreply@ygorstefan.com>

# ========================
# UPLOAD DE IMAGENS
# ========================
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=5242880
